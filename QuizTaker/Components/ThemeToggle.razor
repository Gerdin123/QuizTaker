@rendermode InteractiveServer
@inject IJSRuntime JS
@inject ThemeState ThemeState

<label class="theme-picker">
    <span>Theme</span>
    <select value="@ThemeState.CurrentTheme" @onchange="ChangeThemeAsync" aria-label="Theme">
        @foreach (var theme in Themes)
        {
            <option value="@theme.Value">@theme.Label</option>
        }
    </select>
</label>

@code {
    private static readonly (string Value, string Label)[] Themes =
    [
        ("blue-light", "Blue Light"),
        ("blue-dark", "Blue Dark"),
        ("gray-light", "Grey Light"),
        ("gray-dark", "Grey Dark"),
        ("rose-light", "Pink Light"),
        ("rose-dark", "Pink Dark"),
        ("violet-light", "Purple Light"),
        ("violet-dark", "Purple Dark"),
        ("forest-light", "Forest Light"),
        ("forest-dark", "Forest Dark")
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var theme = await JS.InvokeAsync<string>("quizTakerTheme.get");
        ThemeState.SetTheme(theme);
    }

    private async Task ChangeThemeAsync(ChangeEventArgs eventArgs)
    {
        var nextTheme = Convert.ToString(eventArgs.Value) ?? "light";
        var theme = await JS.InvokeAsync<string>("quizTakerTheme.set", nextTheme);
        ThemeState.SetTheme(theme);
    }
}
