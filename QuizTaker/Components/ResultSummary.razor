<div class="page-heading">
    <div>
        <h1>@Result.Title</h1>
        <p>@Result.Course - @Result.Mode</p>
    </div>
    <a class="btn btn-secondary" href="" data-enhance-nav="false">Home</a>
</div>

<div class="score-panel">
    <div>
        <span>Correct</span>
        <strong>@Result.CorrectCount / @Result.TotalQuestions</strong>
    </div>
    <div>
        <span>Percentage</span>
        <strong>@Result.Percentage%</strong>
    </div>
    <div>
        <span>Status</span>
        <strong>@(Result.ScoreSaved ? "Saved" : "Practice only")</strong>
    </div>
    <div>
        <span>Time taken</span>
        <strong>@FormatDuration(Result.Duration)</strong>
    </div>
</div>

@if (!Result.ScoreSaved)
{
    <div class="alert alert-info">This combined quiz was practice for learning. The score was not saved.</div>
}

<div class="answer-review">
    @foreach (var answer in Result.Answers)
    {
        <article class="review-row @(answer.IsCorrect ? "correct" : "incorrect")">
            <div>
                <span>@answer.Question.QuizTitle</span>
                <h2>@answer.Question.Text</h2>
            </div>
            @if (string.IsNullOrWhiteSpace(answer.SelectedAnswer))
            {
                <p><strong>Your answer:</strong> No answer</p>
            }
            <div class="review-choice-list">
                @foreach (var choice in ChoicesFor(answer))
                {
                    <div class="@ReviewChoiceClass(choice, answer.SelectedAnswer, answer.Question.CorrectAnswer)">
                        <span>@choice</span>
                        @if (string.Equals(choice, answer.Question.CorrectAnswer, StringComparison.Ordinal))
                        {
                            <strong>Correct</strong>
                        }
                        else if (string.Equals(choice, answer.SelectedAnswer, StringComparison.Ordinal))
                        {
                            <strong>Your answer</strong>
                        }
                    </div>
                }
            </div>
        </article>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public QuizRunResult Result { get; set; } = default!;

    private static IReadOnlyList<string> ChoicesFor(QuizRunAnswer answer)
    {
        var choices = answer.Question.Choices.ToList();
        if (!choices.Contains(answer.Question.CorrectAnswer, StringComparer.Ordinal))
        {
            choices.Add(answer.Question.CorrectAnswer);
        }

        if (!string.IsNullOrWhiteSpace(answer.SelectedAnswer)
            && !choices.Contains(answer.SelectedAnswer, StringComparer.Ordinal))
        {
            choices.Add(answer.SelectedAnswer);
        }

        return choices;
    }

    private static string ReviewChoiceClass(string choice, string? selectedAnswer, string correctAnswer)
    {
        var classes = new List<string> { "review-choice" };
        if (string.Equals(choice, correctAnswer, StringComparison.Ordinal))
        {
            classes.Add("correct");
        }

        if (!string.Equals(selectedAnswer, correctAnswer, StringComparison.Ordinal)
            && string.Equals(choice, selectedAnswer, StringComparison.Ordinal))
        {
            classes.Add("incorrect");
        }

        return string.Join(" ", classes);
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return duration.TotalHours >= 1
            ? $"{(int)duration.TotalHours}:{duration.Minutes:00}:{duration.Seconds:00}"
            : $"{duration.Minutes}:{duration.Seconds:00}";
    }
}
