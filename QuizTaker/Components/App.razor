<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <script>
        (() => {
            const themes = ["blue-light", "blue-dark", "gray-light", "gray-dark", "rose-light", "rose-dark", "violet-light", "violet-dark", "forest-light", "forest-dark"];
            const aliases = {
                light: "blue-light",
                dark: "blue-dark",
                gray: "gray-light",
                rose: "rose-light",
                violet: "violet-dark",
                forest: "forest-dark"
            };
            const storedTheme = localStorage.getItem("quiztaker-theme");
            const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
            const aliasedTheme = aliases[storedTheme] ?? storedTheme;
            const theme = themes.includes(aliasedTheme) ? aliasedTheme : (prefersDark ? "blue-dark" : "blue-light");
            document.documentElement.dataset.theme = theme;
            document.documentElement.classList.add(`theme-${theme}`);
        })();
    </script>
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["QuizTaker.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["theme.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
