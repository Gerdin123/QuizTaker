@page "/attempt/{AttemptId:int}"
@rendermode InteractiveServer
@inject QuizSessionService SessionService
@inject QuizCatalogService CatalogService

<PageTitle>Saved Score</PageTitle>

@if (attempt is null)
{
    <div class="empty-state">
        <h1>Saved score not found</h1>
        <a class="btn btn-primary" href="" data-enhance-nav="false">Home</a>
    </div>
}
else
{
    <div class="page-heading">
        <div>
            <h1>@attempt.Title</h1>
            <p>@attempt.Course - @attempt.Mode - @attempt.CompletedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</p>
        </div>
        <a class="btn btn-secondary" href="" data-enhance-nav="false">Home</a>
    </div>

    <div class="score-panel">
        <div>
            <span>Correct</span>
            <strong>@attempt.CorrectCount / @attempt.TotalQuestions</strong>
        </div>
        <div>
            <span>Percentage</span>
            <strong>@ScorePercent(attempt)%</strong>
        </div>
    </div>

    <div class="answer-review">
        @foreach (var answer in attempt.Answers)
        {
            <article class="review-row @(answer.IsCorrect ? "correct" : "incorrect")">
                <div>
                    <span>@answer.SourceQuizTitle</span>
                    <h2>@answer.QuestionText</h2>
                </div>
                @if (string.IsNullOrWhiteSpace(answer.SelectedAnswer))
                {
                    <p><strong>Your answer:</strong> No answer</p>
                }
                <div class="review-choice-list">
                    @foreach (var choice in ChoicesFor(answer))
                    {
                        <div class="@ReviewChoiceClass(choice, answer.SelectedAnswer, answer.CorrectAnswer)">
                            <span>@choice</span>
                            @if (string.Equals(choice, answer.CorrectAnswer, StringComparison.Ordinal))
                            {
                                <strong>Correct</strong>
                            }
                            else if (string.Equals(choice, answer.SelectedAnswer, StringComparison.Ordinal))
                            {
                                <strong>Your answer</strong>
                            }
                        </div>
                    }
                </div>
            </article>
        }
    </div>
}

@code {
    [Parameter]
    public int AttemptId { get; set; }

    private QuizAttempt? attempt;

    protected override async Task OnParametersSetAsync()
    {
        attempt = await SessionService.GetSavedAttemptAsync(AttemptId);
    }

    private static decimal ScorePercent(QuizAttempt savedAttempt)
    {
        return savedAttempt.TotalQuestions == 0 ? 0 : Math.Round((decimal)savedAttempt.CorrectCount / savedAttempt.TotalQuestions * 100, 1);
    }

    private IReadOnlyList<string> ChoicesFor(QuizAttemptAnswer answer)
    {
        var choices = CatalogService.GetCatalog()
            .AllQuizzes
            .Where(quiz => string.Equals(quiz.Title, answer.SourceQuizTitle, StringComparison.Ordinal))
            .SelectMany(quiz => quiz.Questions)
            .FirstOrDefault(question => string.Equals(question.Text, answer.QuestionText, StringComparison.Ordinal))
            ?.Choices
            .ToList() ?? [];

        if (!choices.Contains(answer.CorrectAnswer, StringComparer.Ordinal))
        {
            choices.Add(answer.CorrectAnswer);
        }

        if (!string.IsNullOrWhiteSpace(answer.SelectedAnswer)
            && !choices.Contains(answer.SelectedAnswer, StringComparer.Ordinal))
        {
            choices.Add(answer.SelectedAnswer);
        }

        return choices;
    }

    private static string ReviewChoiceClass(string choice, string? selectedAnswer, string correctAnswer)
    {
        var classes = new List<string> { "review-choice" };
        if (string.Equals(choice, correctAnswer, StringComparison.Ordinal))
        {
            classes.Add("correct");
        }

        if (!string.Equals(selectedAnswer, correctAnswer, StringComparison.Ordinal)
            && string.Equals(choice, selectedAnswer, StringComparison.Ordinal))
        {
            classes.Add("incorrect");
        }

        return string.Join(" ", classes);
    }
}
