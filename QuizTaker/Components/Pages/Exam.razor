@page "/exam"
@rendermode InteractiveServer
@inject QuizCatalogService CatalogService
@inject QuizSessionService SessionService
@inject NavigationManager Navigation

<PageTitle>Exams</PageTitle>

<div class="page-heading">
    <div>
        <h1>Exams</h1>
        <p>Choose the quizzes and question counts to include in a scored exam.</p>
    </div>
    <a class="btn btn-secondary" href="" data-enhance-nav="false">Back to quizzes</a>
</div>

@if (catalog.Courses.Count == 0)
{
    <div class="empty-state">
        <h2>No quizzes found</h2>
        <p>Add quiz text files under the <code>Quizzes</code> folder before creating an exam.</p>
    </div>
}
else
{
    <div class="course-stack">
        @foreach (var course in catalog.Courses)
        {
            <section class="course-section">
                <div class="course-header">
                    <div>
                        <h2>@course.Name</h2>
                        <span>@SelectedExamQuizzes(course).Sum(pair => pair.Count) questions from @SelectedExamQuizzes(course).Count() quizzes</span>
                    </div>
                    <button class="btn btn-primary"
                            disabled="@(!SelectedExamQuizzes(course).Any())"
                            @onclick="() => StartExam(course)">
                        Start exam
                    </button>
                </div>

                <div class="selection-note">
                    All quizzes are selected by default. Click a card to include or remove it, and adjust how many questions should be pulled from each quiz.
                </div>

                <div class="quiz-grid">
                    @foreach (var quiz in course.Quizzes)
                    {
                        var selected = examSelections.Contains(quiz.Id);
                        <article class="quiz-card selectable @(selected ? "selected" : "")"
                                 @onclick="() => ToggleExamQuiz(quiz)">
                            <div>
                                <h3>@quiz.Title</h3>
                                <p>@quiz.Questions.Count available questions</p>
                            </div>
                            <span class="card-state exam-state">@(selected ? "Included" : "Excluded")</span>
                            <label class="number-row" @onclick:stopPropagation="true">
                                <span>Questions</span>
                                <input type="number"
                                       min="1"
                                       max="@quiz.Questions.Count"
                                       value="@GetExamCount(quiz)"
                                       disabled="@(!selected)"
                                       @onchange="eventArgs => SetExamCount(quiz, eventArgs)" />
                            </label>
                        </article>
                    }
                </div>
            </section>
        }
    </div>
}

<section class="history-section">
    <h2>Recent exam scores</h2>
    <div class="filter-bar">
        <label>
            <span>Course</span>
            <select value="@selectedCourse" @onchange="OnCourseFilterChanged">
                <option value="">All</option>
                @foreach (var course in catalog.Courses)
                {
                    <option value="@course.Name">@course.Name</option>
                }
            </select>
        </label>
        <label>
            <span>Quiz</span>
            <select @bind="selectedQuizId">
                <option value="">All</option>
                @foreach (var quiz in FilterQuizOptions())
                {
                    <option value="@quiz.Id">@quiz.Title</option>
                }
            </select>
        </label>
        <button class="btn btn-secondary" type="button" @onclick="ResetFilters">Reset filters</button>
    </div>
    @if (RecentExamAttempts().Count == 0)
    {
        <p>No saved exam scores yet.</p>
    }
    else
    {
        <div class="attempt-list">
            @foreach (var attempt in RecentExamAttempts())
            {
                <a class="attempt-row exam-grade @ExamGradeClass(attempt)" href="@($"attempt/{attempt.Id}")" data-enhance-nav="false">
                    <span>
                        <strong>@attempt.Title</strong>
                        <small>@attempt.Course - @attempt.Mode - @attempt.CompletedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</small>
                    </span>
                    <span class="attempt-score">
                        <strong>@attempt.CorrectCount / @attempt.TotalQuestions (@ScorePercent(attempt)%)</strong>
                        <small>@ExamGradeLabel(attempt)</small>
                    </span>
                </a>
            }
        </div>
    }
</section>

@code {
    private const int DefaultExamQuestionsPerQuiz = 10;

    private QuizCatalog catalog = new([]);
    private IReadOnlyList<QuizAttempt> recentAttempts = [];
    private readonly HashSet<string> examSelections = [];
    private readonly Dictionary<string, int> examCounts = [];
    private string selectedCourse = string.Empty;
    private string selectedQuizId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        catalog = CatalogService.GetCatalog();
        recentAttempts = await SessionService.GetRecentAttemptsAsync();
        foreach (var quiz in catalog.AllQuizzes)
        {
            examSelections.Add(quiz.Id);
            examCounts[quiz.Id] = Math.Min(DefaultExamQuestionsPerQuiz, quiz.Questions.Count);
        }
    }

    private void ToggleExamQuiz(QuizDefinition quiz)
    {
        if (!examSelections.Add(quiz.Id))
        {
            examSelections.Remove(quiz.Id);
        }
    }

    private int GetExamCount(QuizDefinition quiz)
    {
        return examCounts.GetValueOrDefault(quiz.Id, Math.Min(DefaultExamQuestionsPerQuiz, quiz.Questions.Count));
    }

    private void SetExamCount(QuizDefinition quiz, ChangeEventArgs eventArgs)
    {
        var rawValue = Convert.ToString(eventArgs.Value);
        if (!int.TryParse(rawValue, out var count))
        {
            examCounts[quiz.Id] = Math.Min(DefaultExamQuestionsPerQuiz, quiz.Questions.Count);
            return;
        }

        examCounts[quiz.Id] = Math.Clamp(count, 1, quiz.Questions.Count);
    }

    private IEnumerable<(QuizDefinition Quiz, int Count)> SelectedExamQuizzes(CourseGroup course)
    {
        return course.Quizzes
            .Where(quiz => examSelections.Contains(quiz.Id))
            .Select(quiz => (Quiz: quiz, Count: GetExamCount(quiz)))
            .Where(pair => pair.Count > 0);
    }

    private void StartExam(CourseGroup course)
    {
        var selected = SelectedExamQuizzes(course).ToDictionary(pair => pair.Quiz, pair => pair.Count);
        if (selected.Count == 0)
        {
            return;
        }

        var runId = SessionService.StartExam(course.Name, selected);
        Navigation.NavigateTo($"take/{runId}", forceLoad: true);
    }

    private IEnumerable<QuizDefinition> FilterQuizOptions()
    {
        return catalog.Courses
            .Where(course => string.IsNullOrEmpty(selectedCourse) || course.Name == selectedCourse)
            .SelectMany(course => course.Quizzes)
            .OrderBy(quiz => quiz.Title);
    }

    private List<QuizAttempt> RecentExamAttempts()
    {
        return recentAttempts
            .Where(attempt => attempt.Mode == nameof(QuizRunMode.Exam))
            .Where(AttemptMatchesFilters)
            .ToList();
    }

    private bool AttemptMatchesFilters(QuizAttempt attempt)
    {
        if (!string.IsNullOrEmpty(selectedCourse) && attempt.Course != selectedCourse)
        {
            return false;
        }

        if (string.IsNullOrEmpty(selectedQuizId))
        {
            return true;
        }

        var selectedQuiz = catalog.AllQuizzes.FirstOrDefault(quiz => quiz.Id == selectedQuizId);
        return selectedQuiz is not null
            && attempt.SourceSummary.Contains(selectedQuiz.Title, StringComparison.Ordinal);
    }

    private void OnCourseFilterChanged(ChangeEventArgs eventArgs)
    {
        selectedCourse = Convert.ToString(eventArgs.Value) ?? string.Empty;
        selectedQuizId = string.Empty;
    }

    private void ResetFilters()
    {
        selectedCourse = string.Empty;
        selectedQuizId = string.Empty;
    }

    private static decimal ScorePercent(QuizAttempt attempt)
    {
        return attempt.TotalQuestions == 0 ? 0 : Math.Round((decimal)attempt.CorrectCount / attempt.TotalQuestions * 100, 1);
    }

    private static string ExamGradeClass(QuizAttempt attempt)
    {
        var score = ScorePercent(attempt);
        return score switch
        {
            < 60 => "grade-fail",
            < 90 => "grade-pass",
            < 100 => "grade-merit",
            _ => "grade-perfect"
        };
    }

    private static string ExamGradeLabel(QuizAttempt attempt)
    {
        var score = ScorePercent(attempt);
        return score switch
        {
            < 60 => "Fail",
            < 90 => "Passed",
            < 100 => "Passed with merit",
            _ => "Perfect"
        };
    }
}
