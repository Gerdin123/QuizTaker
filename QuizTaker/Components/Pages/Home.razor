@page "/"
@rendermode InteractiveServer
@inject QuizCatalogService CatalogService
@inject QuizSessionService SessionService
@inject NavigationManager Navigation

<PageTitle>Quizzes</PageTitle>

<div class="page-heading">
    <div>
        <h1>Quizzes</h1>
        <p>Start a single quiz or build a combined practice test from one course.</p>
    </div>
    <a class="btn btn-secondary" href="exam" data-enhance-nav="false">Create exam</a>
</div>

@if (catalog.Courses.Count == 0)
{
    <div class="empty-state">
        <h2>No quizzes found</h2>
        <p>Add copied quiz text files under the <code>Quizzes</code> folder. Subfolders become course names; files at the root are grouped as Other.</p>
    </div>
}
else
{
    <div class="course-stack">
        @foreach (var course in catalog.Courses)
        {
            var isCombining = activeCombinedCourse == course.Name;
            <section class="course-section">
                <div class="course-header">
                    <div>
                        <h2>@course.Name</h2>
                        <span>@course.Quizzes.Sum(quiz => quiz.Questions.Count) questions in @course.Quizzes.Count quizzes</span>
                    </div>
                    <div class="course-actions compact">
                        @if (!isCombining)
                        {
                            <button class="btn btn-secondary" @onclick="() => StartCombinedSetup(course)">Start combined test</button>
                        }
                        else
                        {
                            <button class="btn btn-ghost" @onclick="CancelCombinedSetup">Cancel</button>
                            <button class="btn btn-primary"
                                    disabled="@(SelectedPracticeQuizzes(course).Count < 2)"
                                    @onclick="() => StartPractice(course)">
                                Begin selected test
                            </button>
                        }
                    </div>
                </div>

                @if (isCombining)
                {
                    <div class="selection-note">
                        <strong>@SelectedPracticeQuizzes(course).Count selected.</strong>
                        Click quiz cards to include or remove them. Combined tests are practice only and scores are not saved.
                    </div>
                }

                <div class="quiz-grid">
                    @foreach (var quiz in course.Quizzes)
                    {
                        var selected = practiceSelections.Contains(quiz.Id);
                        <article class="quiz-card @(isCombining ? "selectable" : "") @(selected && isCombining ? "selected" : "")"
                                 @onclick="() => TogglePracticeCard(course, quiz)">
                            <div>
                                <h3>@quiz.Title</h3>
                                <p>@quiz.Questions.Count questions</p>
                            </div>
                            @if (isCombining)
                            {
                                <span class="card-state">@(selected ? "Selected" : "Not selected")</span>
                            }
                            else
                            {
                                <div class="card-actions">
                                    <button class="btn btn-primary" @onclick:stopPropagation="true" @onclick="() => StartQuiz(quiz)">Start quiz</button>
                                </div>
                            }
                        </article>
                    }
                </div>
            </section>
        }
    </div>
}

<section class="history-section">
    <h2>Recent quiz scores</h2>
    <div class="filter-bar">
        <label>
            <span>Course</span>
            <select value="@selectedCourse" @onchange="OnCourseFilterChanged">
                <option value="">All</option>
                @foreach (var course in catalog.Courses)
                {
                    <option value="@course.Name">@course.Name</option>
                }
            </select>
        </label>
        <label>
            <span>Quiz</span>
            <select @bind="selectedQuizId">
                <option value="">All</option>
                @foreach (var quiz in FilterQuizOptions())
                {
                    <option value="@quiz.Id">@quiz.Title</option>
                }
            </select>
        </label>
        <button class="btn btn-secondary" type="button" @onclick="ResetFilters">Reset filters</button>
    </div>
    @if (RecentQuizAttempts().Count == 0)
    {
        <p>No saved quiz scores yet.</p>
    }
    else
    {
        <div class="attempt-list">
            @foreach (var attempt in RecentQuizAttempts())
            {
                <a class="attempt-row quiz-grade @QuizGradeClass(attempt)" href="@($"attempt/{attempt.Id}")" data-enhance-nav="false">
                    <span>
                        <strong>@attempt.Title</strong>
                        <small>@attempt.Course - @attempt.Mode - @attempt.CompletedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</small>
                    </span>
                    <span class="attempt-score">
                        <strong>@attempt.CorrectCount / @attempt.TotalQuestions (@ScorePercent(attempt)%)</strong>
                        <small>@QuizGradeLabel(attempt)</small>
                    </span>
                </a>
            }
        </div>
    }
</section>

@code {
    private QuizCatalog catalog = new([]);
    private IReadOnlyList<QuizAttempt> recentAttempts = [];
    private readonly HashSet<string> practiceSelections = [];
    private string? activeCombinedCourse;
    private string selectedCourse = string.Empty;
    private string selectedQuizId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        catalog = CatalogService.GetCatalog();
        recentAttempts = await SessionService.GetRecentAttemptsAsync();
    }

    private void StartQuiz(QuizDefinition quiz)
    {
        var runId = SessionService.StartQuiz(quiz);
        Navigation.NavigateTo($"take/{runId}", forceLoad: true);
    }

    private void StartCombinedSetup(CourseGroup course)
    {
        activeCombinedCourse = course.Name;
        practiceSelections.Clear();
        foreach (var quiz in course.Quizzes)
        {
            practiceSelections.Add(quiz.Id);
        }
    }

    private void CancelCombinedSetup()
    {
        activeCombinedCourse = null;
        practiceSelections.Clear();
    }

    private void TogglePracticeCard(CourseGroup course, QuizDefinition quiz)
    {
        if (activeCombinedCourse != course.Name)
        {
            return;
        }

        if (!practiceSelections.Add(quiz.Id))
        {
            practiceSelections.Remove(quiz.Id);
        }
    }

    private void StartPractice(CourseGroup course)
    {
        var selected = SelectedPracticeQuizzes(course);
        if (selected.Count < 2)
        {
            return;
        }

        var runId = SessionService.StartPractice(course.Name, selected);
        Navigation.NavigateTo($"take/{runId}", forceLoad: true);
    }

    private List<QuizDefinition> SelectedPracticeQuizzes(CourseGroup course)
    {
        return course.Quizzes.Where(quiz => practiceSelections.Contains(quiz.Id)).ToList();
    }

    private IEnumerable<QuizDefinition> FilterQuizOptions()
    {
        return catalog.Courses
            .Where(course => string.IsNullOrEmpty(selectedCourse) || course.Name == selectedCourse)
            .SelectMany(course => course.Quizzes)
            .OrderBy(quiz => quiz.Title);
    }

    private List<QuizAttempt> RecentQuizAttempts()
    {
        return recentAttempts
            .Where(attempt => attempt.Mode == nameof(QuizRunMode.Quiz))
            .Where(AttemptMatchesFilters)
            .ToList();
    }

    private bool AttemptMatchesFilters(QuizAttempt attempt)
    {
        if (!string.IsNullOrEmpty(selectedCourse) && attempt.Course != selectedCourse)
        {
            return false;
        }

        if (string.IsNullOrEmpty(selectedQuizId))
        {
            return true;
        }

        var selectedQuiz = catalog.AllQuizzes.FirstOrDefault(quiz => quiz.Id == selectedQuizId);
        return selectedQuiz is not null && attempt.Title == selectedQuiz.Title;
    }

    private void OnCourseFilterChanged(ChangeEventArgs eventArgs)
    {
        selectedCourse = Convert.ToString(eventArgs.Value) ?? string.Empty;
        selectedQuizId = string.Empty;
        activeCombinedCourse = null;
        practiceSelections.Clear();
    }

    private void ResetFilters()
    {
        selectedCourse = string.Empty;
        selectedQuizId = string.Empty;
        activeCombinedCourse = null;
        practiceSelections.Clear();
    }

    private static decimal ScorePercent(QuizAttempt attempt)
    {
        return attempt.TotalQuestions == 0 ? 0 : Math.Round((decimal)attempt.CorrectCount / attempt.TotalQuestions * 100, 1);
    }

    private static string QuizGradeClass(QuizAttempt attempt)
    {
        var wrongAnswers = attempt.TotalQuestions - attempt.CorrectCount;
        return wrongAnswers switch
        {
            0 => "grade-perfect",
            >= 10 => "grade-fail",
            _ => "grade-pass"
        };
    }

    private static string QuizGradeLabel(QuizAttempt attempt)
    {
        var wrongAnswers = attempt.TotalQuestions - attempt.CorrectCount;
        return wrongAnswers switch
        {
            0 => "Perfect",
            >= 10 => "Fail",
            _ => "Passed"
        };
    }
}
