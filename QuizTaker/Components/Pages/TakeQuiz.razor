@page "/take/{RunId:guid}"
@rendermode InteractiveServer
@inject QuizSessionService SessionService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Take Quiz</PageTitle>

@if (run is null)
{
    <div class="empty-state">
        <h1>Quiz session not found</h1>
        <p>The session may have already been submitted. Return home and start a new quiz.</p>
        <a class="btn btn-primary" href="" data-enhance-nav="false">Home</a>
    </div>
}
else
{
    <div class="page-heading">
        <div>
            <h1>@run.Title</h1>
            <p>@run.Course - @run.Questions.Count questions</p>
        </div>
        @if (run.Mode == QuizRunMode.Practice)
        {
            <span class="status-pill">Practice score will not be saved</span>
        }
        else
        {
            <span class="status-pill saved">Score will be saved</span>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(validationMessage))
    {
        <div class="alert alert-warning">@validationMessage</div>
    }

    <div class="run-metrics" aria-live="polite">
        <div>
            <span>Time elapsed</span>
            <strong>@FormatDuration(elapsed)</strong>
        </div>
        <div>
            <span>Answered</span>
            <strong>@selectedAnswers.Count / @run.Questions.Count</strong>
        </div>
    </div>

    <div class="question-stack">
        @for (var i = 0; i < run.Questions.Count; i++)
        {
            var question = run.Questions[i];
            <section class="question-card">
                <div class="question-meta">
                    <strong>Question @(i + 1)</strong>
                    <span>@question.QuizTitle</span>
                </div>
                <h2>@question.Text</h2>
                <div class="choice-list">
                    @foreach (var choice in question.Choices)
                    {
                        <label class="choice-row @(IsSelected(question.Id, choice) ? "selected" : "")">
                            <input type="radio"
                                   name="@question.Id"
                                   value="@choice"
                                   checked="@(selectedAnswers.GetValueOrDefault(question.Id) == choice)"
                                   @onchange="eventArgs => SelectAnswer(question.Id, Convert.ToString(eventArgs.Value) ?? string.Empty)" />
                            <span>@choice</span>
                        </label>
                    }
                </div>
            </section>
        }
    </div>

    <div class="submit-bar">
        <span>@selectedAnswers.Count / @run.Questions.Count answered</span>
        <button class="btn btn-primary btn-lg" @onclick="SubmitAsync">Submit</button>
    </div>
}

@code {
    [Parameter]
    public Guid RunId { get; set; }

    private QuizRun? run;
    private readonly Dictionary<string, string> selectedAnswers = [];
    private TimeSpan elapsed;
    private Timer? elapsedTimer;
    private string? validationMessage;

    protected override void OnParametersSet()
    {
        run = SessionService.GetRun(RunId);
        elapsedTimer?.Dispose();
        elapsedTimer = null;

        if (run is not null)
        {
            UpdateElapsed();
            elapsedTimer = new Timer(_ => InvokeAsync(() =>
            {
                UpdateElapsed();
                StateHasChanged();
            }), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
        }
    }

    private void SelectAnswer(string questionId, string choice)
    {
        selectedAnswers[questionId] = choice;
        validationMessage = null;
    }

    private bool IsSelected(string questionId, string choice)
    {
        return selectedAnswers.TryGetValue(questionId, out var selectedAnswer)
            && selectedAnswer == choice;
    }

    private async Task SubmitAsync()
    {
        if (run is null)
        {
            return;
        }

        if (selectedAnswers.Count < run.Questions.Count)
        {
            validationMessage = "Answer every question before submitting.";
            return;
        }

        var result = await SessionService.CompleteRunAsync(run.Id, selectedAnswers);
        if (result is not null)
        {
            elapsedTimer?.Dispose();
            elapsedTimer = null;
            Navigation.NavigateTo($"results/{run.Id}", forceLoad: true);
        }
    }

    private void UpdateElapsed()
    {
        elapsed = run is null ? TimeSpan.Zero : DateTimeOffset.UtcNow - run.StartedAt;
    }

    private static string FormatDuration(TimeSpan duration)
    {
        return duration.TotalHours >= 1
            ? $"{(int)duration.TotalHours}:{duration.Minutes:00}:{duration.Seconds:00}"
            : $"{duration.Minutes}:{duration.Seconds:00}";
    }

    public void Dispose()
    {
        elapsedTimer?.Dispose();
    }
}
